# Core
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/edusys
SECRET_KEY=change-me

# WebRTC TURN (required for calls across different networks)
# Option A: Static TURN server
TURN_URLS=turn:your-turn.example.com:3478?transport=udp,turn:your-turn.example.com:3478?transport=tcp
TURN_USERNAME=your-username
TURN_CREDENTIAL=your-password

# Option B: Cloudflare TURN (short-lived credentials)
# CF_TURN_KEY_ID=your-key-id
# CF_TURN_API_TOKEN=your-api-token
